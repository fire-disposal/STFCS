{
  "$schema": "https://v2-9-6.turborepo.dev/schema.json",
  "globalDependencies": [
    "package.json",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "tsconfig.base.json",
    "turbo.json"
  ],
  "globalEnv": [
    "CI",
    "NODE_ENV",
    "PORT",
    "WS_PORT",
    "CORS_ORIGINS"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "lint:fix": {
      "cache": false
    },
    "format": {
      "cache": false
    },
    "format:check": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:client": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "dev:server": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    }
  }
}
