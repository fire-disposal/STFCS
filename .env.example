# =============================================
# STFCS Environment Configuration Example
# Copy this file to .env and update values
# =============================================

# =============================================
# Server Configuration
# =============================================
HTTP_PORT=3000
WS_PORT=3001
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080
LOG_LEVEL=info
MAX_PLAYERS_PER_ROOM=8

# =============================================
# GitHub Actions Secrets (for CI/CD)
# =============================================
# These should be configured in GitHub repository settings

# SSH_PRIVATE_KEY: Private key for SSH access to production server
# Format: -----BEGIN OPENSSH PRIVATE KEY-----
#         ...
#         -----END OPENSSH PRIVATE KEY-----

# SERVER_HOST: Production server IP or domain
# Example: 123.45.67.89 or stfcs.yourdomain.com

# SERVER_USER: SSH username for production server
# Example: root or ubuntu or deploy

# GITHUB_TOKEN: Automatically provided by GitHub Actions

# CORS_ORIGINS: Comma-separated list of allowed origins for production
# Example: https://stfcs.yourdomain.com,https://www.yourdomain.com
