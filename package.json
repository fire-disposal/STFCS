{
	"name": "virtual-tabletop",
	"private": true,
	"version": "1.0.0",
	"description": "STFCS - Tactical Space Fleet Combat System",
	"scripts": {
		"lint": "turbo run lint --continue",
		"lint:fix": "turbo run lint:fix --continue",
		"format": "turbo run format --continue",
		"format:check": "turbo run format:check --continue",
		"test": "turbo run test --continue",
		"build": "turbo run build --continue",
		"dev": "pnpm --filter @vt/data build && turbo run dev --filter=@vt/server --filter=client",
		"dev:legacy": "turbo run dev",
		"dev:server": "turbo run dev:server",
		"dev:client": "turbo run dev:client",
		"typecheck": "turbo run typecheck --continue",
		"check": "pnpm lint && pnpm typecheck"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@10.32.1",
	"overrides": {
		"@colyseus/schema": "^4.0.19"
	},
	"devDependencies": {
		"@eslint/js": "^9.15.0",
		"@types/json-schema": "^7.0.15",
		"@types/node": "^25.4.0",
		"@typescript-eslint/eslint-plugin": "^8.16.0",
		"@typescript-eslint/parser": "^8.16.0",
		"eslint": "^9.15.0",
		"eslint-plugin-vue": "^9.31.0",
		"globals": "^15.12.0",
		"turbo": "^2.9.6",
		"typescript": "^5.9.3",
		"vue-eslint-parser": "^9.4.3"
	}
}
