{
  "name": "@vt/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js",
    "./types": "./dist/types/index.js",
    "./schemas": "./dist/schemas/index.js",
    "./constants": "./dist/constants/index.js",
    "./protocol": "./dist/protocol/index.js",
    "./core-types": "./dist/core-types.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --sourcemap --treeshake",
    "dev": "tsup src/index.ts --format esm --dts --watch --sourcemap",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome lint src --diagnostic-level=error",
    "lint:fix": "biome lint --write src --diagnostic-level=error",
    "format": "biome format --write src",
    "format:check": "biome format src"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@colyseus/schema": "^4.0.19",
    "gl-matrix": "^3.4.4",
    "sat": "^0.9.0",
    "zod": "^4.3.6"
  }
}
