{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@vt/shared": ["../shared/src/index.ts"],
      "@vt/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src/**/*", "../shared/src/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/__tests__/*", "**/*.backup.ts"]
}
