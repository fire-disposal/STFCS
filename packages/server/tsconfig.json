{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"experimentalDecorators": true,
		"useDefineForClassFields": false,
		"lib": ["ES2022"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "./dist",
		"types": ["node", "vitest/globals"],
		"baseUrl": "../..",
		"paths": {
			"@vt/rules": ["packages/rules/src/index.ts"],
			"@vt/contracts": ["packages/contracts/src/index.ts"]
		}
	},
	"include": [
		"src/index.ts",
		"src/rooms/**/*.ts",
		"src/commands/**/*.ts",
		"src/services/**/*.ts",
		"src/http/**/*.ts",
		"src/schema/**/*.ts",
		"src/types/**/*.ts"
	],
	"exclude": ["node_modules", "dist", "**/__tests__/*", "**/*.backup.ts"]
}
