{
  "name": "server",
  "version": "1.0.0",
  "description": "STFCS Backend Server",
  "main": "src/app/main.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app/main.ts",
    "start": "tsx src/app/main.ts",
    "build": "tsup src/app/main.ts --format cjs --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
