{
  "name": "server",
  "version": "1.0.0",
  "description": "STFCS Backend Server",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome lint src --diagnostic-level=error",
    "lint:fix": "biome lint --write src --diagnostic-level=error",
    "format": "biome format --write src",
    "format:check": "biome format src"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@colyseus/core": "^0.17.41",
    "@colyseus/monitor": "^0.17.8",
    "@colyseus/ws-transport": "^0.17.13",
    "@vt/shared": "workspace:*",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "vitest": "^3.2.4"
  }
}
