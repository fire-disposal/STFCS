{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json --noEmit && vite build",
    "preview": "vite preview",
    "format": "biome format --write src",
    "format:check": "biome format src",
    "lint": "biome lint src --diagnostic-level=error",
    "lint:fix": "biome lint --write src --diagnostic-level=error",
    "check": "biome check src --diagnostic-level=error",
    "check:fix": "biome check --write src --diagnostic-level=error",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --watch --passWithNoTests",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc -p tsconfig.app.json --noEmit"
  },
  "dependencies": {
    "@pixi/react": "^8.0.5",
    "@reduxjs/toolkit": "^2.5.0",
    "@tanstack/react-query": "^5.60.0",
    "@vt/shared": "workspace:*",
    "framer-motion": "^11.18.0",
    "i18next": "^25.8.18",
    "i18next-browser-languagedetector": "^8.2.1",
    "konva": "^9.3.15",
    "lucide-react": "^0.460.0",
    "pixi.js": "^8.17.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.5.8",
    "react-konva": "^19.0.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.28.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@eslint/js": "^9.15.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.4.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "~5.9.3",
    "vite": "^6.2.0",
    "vitest": "^3.0.0"
  }
}
