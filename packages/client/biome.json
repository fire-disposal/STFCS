{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noBannedTypes": "error",
				"noUselessConstructor": "error",
				"noUselessFragments": "error",
				"noUselessThisAlias": "error",
				"noUselessTypeConstraint": "error",
				"useOptionalChain": "error"
			},
			"correctness": {
				"noUnusedVariables": "error",
				"useExhaustiveDependencies": "error",
				"useHookAtTopLevel": "error",
				"noUnusedImports": "error"
			},
			"style": {
				"noNamespace": "error",
				"useConst": "error",
				"useFragmentSyntax": "error"
			},
			"suspicious": {
				"noExplicitAny": "warn",
				"noConsole": "off",
				"noEmptyBlockStatements": "error"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 100,
		"lineEnding": "lf"
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"trailingComma": "es5",
			"semicolons": "always"
		}
	},
	"files": {
		"ignore": [
			"node_modules",
			"dist",
			"build",
			"coverage",
			".next",
			".vscode",
			"*.config.*",
			"*.test.*",
			"*.spec.*"
		]
	}
}
