{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ship-v2",
  "title": "STFCS Ship JSON Schema (Simplified)",
  "description": "舰船统一数据模型（扁平化结构，面向工程实现）",

  "type": "object",

  "required": ["$schema", "$id", "ship"],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "ship-v2",
      "description": "Schema版本标识"
    },
    "$id": {
      "type": "string",
      "description": "舰船唯一ID（ship:xxx 或 preset:xxx）"
    },
    "$presetRef": {
      "type": "string",
      "description": "引用的预设ID"
    },

    "ship": {
      "type": "object",
      "description": "舰船核心规格（扁平化）",
      "required": [
        "size",
        "class",
        "maxHitPoints",
        "armorMaxPerQuadrant",
        "maxSpeed",
        "maxTurnRate"
      ],
      "properties": {
        "size": {
          "type": "string",
          "enum": ["FRIGATE", "DESTROYER", "CRUISER", "CAPITAL"],
          "description": "舰船尺寸级别"
        },
        "class": {
          "type": "string",
          "enum": ["STRIKE", "ASSAULT", "COMBAT", "SUPPORT", "HEAVY", "CARRIER", "BATTLESHIP"],
          "description": "舰船类别"
        },
        "width": {
          "type": "number",
          "minimum": 10,
          "description": "船体宽度"
        },
        "length": {
          "type": "number",
          "minimum": 10,
          "description": "船体长度"
        },
        "maxHitPoints": {
          "type": "number",
          "minimum": 0,
          "description": "最大生命值"
        },
        "armorMaxPerQuadrant": {
          "type": "number",
          "minimum": 0,
          "description": "单象限护甲上限"
        },
        "armorMinReduction": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.1,
          "description": "最小护甲减伤比例"
        },
        "armorMaxReduction": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.85,
          "description": "最大护甲减伤比例"
        },
        "fluxCapacity": {
          "type": "number",
          "minimum": 0,
          "description": "辐能容量上限"
        },
        "fluxDissipation": {
          "type": "number",
          "minimum": 0,
          "description": "每回合辐散量"
        },
        "shield": {
          "type": "object",
          "description": "护盾配置",
          "required": ["arc", "direction", "radius", "efficiency", "upkeep"],
          "properties": {
            "arc": {
              "type": "number",
              "minimum": 0,
              "maximum": 360,
              "description": "护盾覆盖角度"
            },
            "direction": {
              "type": "number",
              "minimum": 0,
              "maximum": 360,
              "default": 0,
              "description": "护盾中心线相对于船头的角度偏移（0=正前方）"
            },
            "radius": {
              "type": "number",
              "minimum": 0,
              "description": "护盾半径"
            },
            "efficiency": {
              "type": "number",
              "minimum": 0,
              "default": 1.0,
              "description": "护盾效率"
            },
            "upkeep": {
              "type": "number",
              "minimum": 0,
              "default": 0,
              "description": "护盾维持消耗"
            }
          },
          "additionalProperties": false
        },
        "maxSpeed": {
          "type": "number",
          "minimum": 0,
          "description": "最大移动力"
        },
        "maxTurnRate": {
          "type": "number",
          "minimum": 0,
          "description": "最大转向角度"
        },

        "mounts": {
          "type": "array",
          "description": "武器挂点列表",
          "items": {
            "type": "object",
            "required": ["id", "position", "mountType", "size"],
            "properties": {
              "id": {
                "type": "string",
                "description": "挂点ID"
              },
              "displayName": {
                "type": "string",
                "description": "显示名称"
              },
              "position": {
                "type": "object",
                "description": "挂点位置",
                "required": ["x", "y"],
                "properties": {
                  "x": { "type": "number", "description": "X坐标" },
                  "y": { "type": "number", "description": "Y坐标" }
                },
                "additionalProperties": false
              },
              "facing": {
                "type": "number",
                "description": "基准朝向"
              },
              "mountType": {
                "type": "string",
                "enum": ["TURRET", "HARDPOINT"],
                "description": "挂载类型（固定 / 炮塔）"
              },
              "size": {
                "type": "string",
                "enum": ["SMALL", "MEDIUM", "LARGE"],
                "description": "槽位尺寸（小 / 中 / 大）"
              },
              "weapon": {
                "oneOf": [
                  { "$ref": "weapon.schema.json#" },
                  { "type": "string" }
                ],
                "description": "武器或武器ID"
              },
              "group": {
                "type": "string",
                "description": "武器分组"
              }
            },
            "additionalProperties": false
          }
        },

        "plugins": {
          "type": "array",
          "description": "插件槽位",
          "items": {
            "type": "object",
            "description": "插件栏位",
            "required": ["id", "name"],
            "properties": {
              "id": { "type": "string", "description": "插件唯一ID" },
              "name": { "type": "string", "description": "插件名称" },
              "description": { "type": "string", "description": "插件描述" }
            },
            "additionalProperties": false
          }
        },
        "rangeModifier": {
          "type": "number",
          "default": 1.0,
          "description": "射程修正"
        },
        "texture": {
          "$ref": "common.schema.json#/definitions/Texture",
          "description": "贴图资源"
        }
      },
      "additionalProperties": false
    },

    "runtime": {
      "type": "object",
      "description": "舰船运行时状态",
      "required": ["position", "heading", "hull"],
      "properties": {
        "position": {
          "type": "object",
          "description": "当前位置",
          "required": ["x", "y"],
          "properties": {
            "x": { "type": "number", "description": "X坐标" },
            "y": { "type": "number", "description": "Y坐标" }
          },
          "additionalProperties": false
        },
        "heading": {
          "type": "number",
          "description": "朝向角度"
        },
        "hull": {
          "type": "number",
          "minimum": 0,
          "description": "当前生命值"
        },
        "armor": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "items": { "type": "number", "minimum": 0 },
          "description": "六象限护甲"
        },
        "fluxSoft": {
          "type": "number",
          "minimum": 0,
          "description": "软辐能"
        },
        "fluxHard": {
          "type": "number",
          "minimum": 0,
          "description": "硬辐能"
        },
        "shield": {
          "type": "object",
          "description": "护盾运行时状态",
          "required": ["active", "value"],
          "properties": {
            "active": {
              "type": "boolean",
              "description": "护盾是否开启"
            },
            "value": {
              "type": "number",
              "minimum": 0,
              "description": "当前护盾值"
            }
          },
          "additionalProperties": false
        },
        "overloaded": {
          "type": "boolean",
          "default": false,
          "description": "是否过载"
        },
        "overloadTime": {
          "type": "integer",
          "minimum": 0,
          "default": 1,
          "description": "过载剩余回合"
        },
        "destroyed": {
          "type": "boolean",
          "default": false,
          "description": "是否已被摧毁"
        },
        "statusEffects": {
          "type": "array",
          "default": [],
          "description": "状态效果列表",
          "items": {
            "type": "object",
            "required": ["id", "type"],
            "properties": {
              "id": {
                "type": "string",
                "description": "效果唯一ID"
              },
              "type": {
                "type": "string",
                "description": "效果类型"
              },
              "source": {
                "type": "string",
                "description": "效果来源（如武器ID、技能ID）"
              },
              "duration": {
                "type": "integer",
                "minimum": 0,
                "description": "剩余持续回合"
              },
              "stackCount": {
                "type": "integer",
                "minimum": 1,
                "default": 1,
                "description": "叠加层数"
              },
              "data": {
                "type": "object",
                "description": "效果附加数据"
              }
            },
            "additionalProperties": false
          }
        },
        "movement": {
          "type": "object",
          "description": "移动状态",
          "properties": {
            "hasMoved": {
              "type": "boolean",
              "description": "本回合是否移动"
            },
            "phaseAUsed": {
              "type": "number",
              "minimum": 0,
              "default": 0,
              "description": "阶段A已使用的移动力"
            },
            "turnAngleUsed": {
              "type": "number",
              "minimum": 0,
              "default": 0,
              "description": "转向阶段已使用的转向角度"
            },
            "phaseCUsed": {
              "type": "number",
              "minimum": 0,
              "default": 0,
              "description": "阶段C已使用的移动力"
            }
          },
          "additionalProperties": false
        },
        "hasFired": {
          "type": "boolean",
          "description": "本回合是否开火"
        },
        "weapons": {
          "type": "array",
          "items": {
            "$ref": "weapon.schema.json#/properties/runtime"
          },
          "description": "武器状态"
        },
        "faction": {
          "$ref": "common.schema.json#/definitions/Faction",
          "description": "所属派系"
        },
        "ownerId": {
          "type": "string",
          "description": "玩家ID"
        }
      },
      "additionalProperties": false
    },
    "metadata": {
      "$ref": "common.schema.json#/definitions/Metadata",
      "description": "元数据"
    }
  },

  "additionalProperties": false
}