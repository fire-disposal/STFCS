{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "weapon-v2",
  "title": "STFCS Weapon JSON (Simplified)",
  "description": "武器统一数据模型（扁平化结构，面向工程实现）",

  "type": "object",

  "required": ["$schema", "$id", "weapon"],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "weapon-v2",
      "description": "Schema版本标识"
    },
    "$id": {
      "type": "string",
      "description": "武器唯一ID（格式: weapon:xxx 或 preset:xxx）"
    },
    "weapon": {
      "type": "object",
      "description": "武器核心属性（已扁平化）",
      "required": [
        "category",
        "damageType",
        "size",
        "damage",
        "range",
        "cooldown",
        "fluxCostPerShot",
        "opCost"
      ],
      "properties": {
        "category": {
          "type": "string",
          "enum": ["BALLISTIC", "ENERGY", "MISSILE", "SYNERGY"],
          "description": "武器类别（能量 / 实弹 / 导弹等）"
        },
        "damageType": {
          "type": "string",
          "enum": ["KINETIC", "HIGH_EXPLOSIVE", "ENERGY", "FRAGMENTATION"],
          "description": "伤害类型（动能 / 能量 / 高爆等）"
        },
        "size": {
          "type": "string",
          "enum": ["SMALL", "MEDIUM", "LARGE"],
          "description": "槽位尺寸（小 / 中 / 大）"
        },
        "damage": {
          "type": "number",
          "minimum": 0,
          "description": "单发伤害"
        },
        "projectilesPerShot": {
          "type": "integer",
          "minimum": 1,
          "default": 1,
          "description": "每次攻击发射的弹体数量"
        },
        "range": {
          "type": "number",
          "minimum": 0,
          "description": "最大射程"
        },
        "minRange": {
          "type": "number",
          "minimum": 0,
          "default": 0,
          "description": "最小射程"
        },
        "cooldown": {
          "type": "number",
          "minimum": 0,
          "default": 0,
          "description": "攻击冷却时间（回合）"
        },
        "fluxCostPerShot": {
          "type": "number",
          "minimum": 0,
          "description": "单发辐能消耗"
        },
        "allowsMultipleTargets": {
          "type": "boolean",
          "default": false,
          "description": "是否支持多目标"
        },
        "burstCount": {
          "type": "integer",
          "minimum": 1,
          "default": 1,
          "description": "最高连射"
        },
        "opCost": {
          "type": "integer",
          "minimum": 0,
          "default": 1,
          "description": "OP点消耗"
        },
        "tags": {
          "type": "array",
          "description": "扩展标签（用于特殊行为或筛选）",
          "items": {
            "type": "string",
            "enum": ["ANTI_SHIP", "PD"],
            "description": "武器标签"
          }
        },
        "texture": {
          "$ref": "common.schema.json#/definitions/Texture",
          "description": "武器贴图资源"
        }
      },
      "additionalProperties": false
    },

    "runtime": {
      "type": "object",
      "description": "运行时状态（战斗中动态变化）",
      "required": ["mountId", "state"],
      "properties": {
        "mountId": {
          "type": "string",
          "description": "所属挂点ID"
        },
        "state": {
          "type": "string",
          "enum": ["READY", "COOLDOWN", "DISABLED"],
          "description": "当前状态（待机 / 冷却 / 禁用等）"
        },
        "cooldownRemaining": {
          "type": "number",
          "minimum": 0,
          "default": 0,
          "description": "剩余冷却回合"
        },
        "statusEffects": {
          "type": "array",
          "default": [],
          "description": "状态效果列表",
          "items": {
            "type": "object",
            "required": ["id", "type"],
            "properties": {
              "id": { "type": "string", "description": "效果唯一ID" },
              "type": { "type": "string", "description": "效果类型" },
              "source": { "type": "string", "description": "效果来源" },
              "duration": { "type": "integer", "minimum": 0, "description": "剩余持续回合" },
              "stackCount": { "type": "integer", "minimum": 1, "default": 1, "description": "叠加层数" },
              "data": { "type": "object", "description": "效果附加数据" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "metadata": {
      "$ref": "common.schema.json#/definitions/Metadata",
      "description": "元数据（创建时间、作者等）"
    }
  },

  "additionalProperties": false
}
