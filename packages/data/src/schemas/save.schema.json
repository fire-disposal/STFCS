{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "save-v1",
	"title": "STFCS Game Save JSON Schema",
	"description": "游戏存档JSON格式",

	"type": "object",
	"required": ["$schema", "$id", "room", "ships"],
	"properties": {
		"$schema": {
			"type": "string",
			"const": "save-v1",
			"description": "Schema版本标识"
		},
		"$id": {
			"type": "string",
			"description": "存档唯一ID，格式 save:xxx"
		},

		"metadata": {
			"type": "object",
			"description": "存档元数据",
			"required": ["name", "createdAt"],
			"properties": {
				"name": {
					"type": "string",
					"description": "存档名称"
				},
				"description": {
					"type": "string",
					"description": "存档描述"
				},
				"createdAt": {
					"type": "integer",
					"description": "创建时间戳"
				},
				"updatedAt": {
					"type": "integer",
					"description": "更新时间戳"
				},
				"roomId": {
					"type": "string",
					"description": "房间ID"
				}
			},
			"additionalProperties": false
		},

		"room": {
			"type": "object",
			"description": "房间运行时状态",
			"required": ["turn", "map", "players"],
			"properties": {
				"turn": {
					"type": "object",
					"description": "回合状态",
					"required": ["count", "phase", "activeFaction"],
					"properties": {
						"count": {
							"type": "integer",
							"minimum": 0,
							"description": "回合计数"
						},
						"phase": {
							"type": "string",
							"enum": ["DEPLOYMENT", "PLAYER_ACTION", "DM_ACTION", "TURN_END"],
							"description": "游戏阶段"
						},
						"activeFaction": {
							"type": "string",
							"enum": ["PLAYER", "ENEMY", "NEUTRAL"],
							"description": "当前行动派系"
				},
				"combatLog": {
					"type": "array",
					"default": [],
					"description": "战斗日志",
					"items": {
						"type": "object",
						"required": ["turn", "type", "timestamp"],
						"properties": {
							"turn": {
								"type": "integer",
								"description": "发生回合"
							},
							"type": {
								"type": "string",
								"description": "事件类型"
							},
							"timestamp": {
								"type": "integer",
								"description": "时间戳"
							},
							"actorId": {
								"type": "string",
								"description": "行动者ID"
							},
							"targetId": {
								"type": "string",
								"description": "目标ID"
							},
							"data": {
								"type": "object",
								"description": "事件附加数据"
							}
						},
						"additionalProperties": false
					}
				}
			},
			"additionalProperties": false
		},

		"map": {
			"type": "object",
			"description": "地图配置",
			"required": ["width", "height"],
			"properties": {
				"width": {
					"type": "number",
					"minimum": 100,
					"description": "地图宽度"
				},
				"height": {
					"type": "number",
					"minimum": 100,
					"description": "地图高度"
				},
				"obstacles": {
					"type": "array",
					"default": [],
					"description": "障碍物/区域列表",
					"items": {
						"type": "object",
						"required": ["nodes"],
						"properties": {
							"id": {
								"type": "string",
								"description": "区域ID"
							},
							"nodes": {
								"type": "array",
								"minItems": 3,
								"description": "封闭区域顶点列表（至少3点）",
								"items": {
									"type": "object",
									"required": ["x", "y"],
									"properties": {
										"x": { "type": "number", "description": "X坐标" },
										"y": { "type": "number", "description": "Y坐标" }
									},
									"additionalProperties": false
								}
							},
							"tags": {
								"type": "array",
								"default": [],
								"items": { "type": "string" },
								"description": "区域标签（用于扩展区域效果）"
							}
						},
						"additionalProperties": false
					}
				}
			},
			"additionalProperties": false
		},

				"players": {
					"type": "array",
					"default": [],
					"description": "玩家列表",
					"items": {
						"type": "object",
						"description": "玩家状态存档",
						"required": ["sessionId", "role"],
						"properties": {
							"sessionId": {
								"type": "string",
								"description": "会话ID"
							},
							"shortId": {
								"type": "integer",
								"description": "短ID"
							},
							"role": {
								"type": "string",
								"enum": ["DM", "PLAYER", "OBSERVER"],
								"description": "玩家角色"
							},
							"name": {
								"type": "string",
								"description": "玩家名称"
							},
							"nickname": {
								"type": "string",
								"description": "玩家昵称"
							},
							"isReady": {
								"type": "boolean",
								"default": false,
								"description": "是否就绪"
							}
						},
						"additionalProperties": false
					}
				}
			},
			"additionalProperties": false
		},

		"ships": {
			"type": "array",
			"description": "舰船列表（含完整规格和运行时状态）",
			"items": {
				"allOf": [
					{ "$ref": "ship.schema.json#" },
					{ "required": ["runtime"] }
				]
			}
		}
	},
	"additionalProperties": false
}
