{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "export-v1",
	"title": "STFCS Export JSON Schema",
	"description": "舰船/武器导出分享格式",

	"type": "object",
	"required": ["$schema", "$type", "$exportedAt"],
	"oneOf": [
		{ "required": ["ship"] },
		{ "required": ["weapon"] },
		{ "required": ["fleet"] }
	],
	"properties": {
		"$schema": {
			"type": "string",
			"const": "export-v1",
			"description": "Schema版本标识"
		},
		"$type": {
			"type": "string",
			"enum": ["SHIP", "WEAPON", "FLEET"],
			"description": "导出类型"
		},
		"$exportedAt": {
			"type": "string",
			"format": "date-time",
			"description": "导出时间（ISO 8601格式）"
		},

		"ship": {
			"$ref": "ship.schema.json#",
			"description": "导出的舰船数据（$type为SHIP时）"
		},

		"weapon": {
			"$ref": "weapon.schema.json#",
			"description": "导出的武器数据（$type为WEAPON时）"
		},

		"fleet": {
			"type": "object",
			"description": "导出的舰队数据（$type为FLEET时）",
			"required": ["name", "ships"],
			"properties": {
				"name": {
					"type": "string",
					"description": "舰队名称"
				},
				"description": {
					"type": "string",
					"description": "舰队描述"
				},
				"ships": {
					"type": "array",
					"items": { "$ref": "ship.schema.json#" },
					"description": "舰队舰船列表"
				}
			},
			"additionalProperties": false
		}
	},
	"additionalProperties": false
}