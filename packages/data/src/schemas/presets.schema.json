{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "presets-v1",
	"title": "STFCS Presets Collection JSON Schema",
	"description": "预设舰船和武器集合格式",

	"type": "object",
	"required": ["$schema"],
	"properties": {
		"$schema": {
			"type": "string",
			"const": "presets-v1",
			"description": "Schema版本标识"
		},
		"description": {
			"type": "string",
			"description": "预设集描述"
		},

		"ships": {
			"type": "array",
			"items": { "$ref": "ship.schema.json#" },
			"default": [],
			"description": "预设舰船列表"
		},

		"weapons": {
			"type": "array",
			"items": { "$ref": "weapon.schema.json#" },
			"default": [],
			"description": "预设武器列表"
		}
	},
	"additionalProperties": false
}