		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@vt/data": "workspace:*",
		"gl-matrix": "^3.4.4",
		"sat": "^0.9.0"
	},
	"devDependencies": {
		"@types/node": "^25.4.0",
		"@types/sat": "^0.0.35",
		"tsup": "^8.5.1",
		"typescript": "~5.9.3"
	}
}
