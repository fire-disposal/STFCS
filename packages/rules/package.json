{
	"name": "@vt/rules",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"main": "./dist/index.js",
	"exports": {
		".": "./dist/index.js",
		"./math": "./dist/index.js"
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm --clean --sourcemap --external @vt/data",
